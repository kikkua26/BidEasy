# ── 应用配置 ──
APP_NAME=奇易AI编标
APP_VERSION=0.1.0
DEBUG=true

# ── 数据库（开发默认 SQLite，生产环境改为 postgresql+asyncpg://...）──
DATABASE_URL=sqlite+aiosqlite:///./data/qiyi_ai_bid.db
DATABASE_URL_SYNC=sqlite:///./data/qiyi_ai_bid.db

# ── AI 服务 ──
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o
AI_TEMPERATURE=0.7

# ── 文件存储 ──
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ── 服务端口 ──
HOST=0.0.0.0
PORT=8000
